PORT=4000
JWT_SECRET=cambia_este_secreto_en_produccion_largo_y_aleatorio

# ── Almacenamiento JSON local (modo desarrollo sin Supabase) ──────────────────
# Ruta relativa al directorio server/ o ruta absoluta.
JSON_DB_PATH=./data/shc-data.json

# ── Supabase (base de datos PostgreSQL en la nube) ────────────────────────────
# Obtén estos valores en: tu-proyecto.supabase.co → Settings → API
#
# URL pública del proyecto (NO contiene secretos)
SUPABASE_URL=https://<tu-proyecto>.supabase.co
#
# Service Role Key (SECRETA – nunca la expongas en el cliente/frontend)
# Tiene acceso total sin restricciones de RLS.
SUPABASE_SERVICE_KEY=eyJ...tu-service-role-key...

# ── Modo de almacenamiento ────────────────────────────────────────────────────
# "json"     → usa JSON local (JSON_DB_PATH)     [por defecto]
# "supabase" → usa Supabase (SUPABASE_URL + SUPABASE_SERVICE_KEY)
STORAGE_MODE=json
